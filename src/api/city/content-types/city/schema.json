{
  "kind": "collectionType",
  "collectionName": "cities",
  "info": {
    "singularName": "city",
    "pluralName": "cities",
    "displayName": "City",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "state": {
      "type": "string",
      "required": true
    },
    "stateCode": {
      "type": "string",
      "maxLength": 2,
      "required": true
    },
    "cityIntro": {
      "type": "richtext"
    },
    "cityVendingScene": {
      "type": "richtext"
    },
    "cityStats": {
      "type": "component",
      "component": "shared.stat",
      "repeatable": true
    },
    "cityFAQs": {
      "type": "component",
      "component": "city.faq",
      "repeatable": true
    },
    "aiGeneratedAt": {
      "type": "datetime"
    },
    "contentStatus": {
      "type": "enumeration",
      "default": "needs-content",
      "enum": [
        "needs-content",
        "ai-draft",
        "human-reviewed",
        "published"
      ]
    },
    "wordCount": {
      "type": "integer",
      "default": 0
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "cityIndustryPages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::city-industry-page.city-industry-page",
      "mappedBy": "city"
    },
    "industries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::industry.industry",
      "inversedBy": "cities"
    },
    "locationName": {
      "type": "string"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "cityImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "cityCta": {
      "type": "component",
      "component": "blocks.cta",
      "repeatable": false
    },
    "cityReviews": {
      "type": "component",
      "component": "shared.testimonial",
      "repeatable": true
    },
    "cityLocationGrid": {
      "type": "component",
      "component": "blocks.locations-grid",
      "repeatable": false
    }
  }
}
