{
  "kind": "collectionType",
  "collectionName": "resource_pages",
  "info": {
    "singularName": "resource-page",
    "pluralName": "resource-pages",
    "displayName": "Resource Page",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "maxLength": 160
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "faqItems": {
      "type": "component",
      "repeatable": true,
      "component": "resource.faq"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
