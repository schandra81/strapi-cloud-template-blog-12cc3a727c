{
  "kind": "collectionType",
  "collectionName": "resource_sections",
  "info": {
    "singularName": "blog-section",
    "pluralName": "blog-sections",
    "displayName": "Blog Section",
    "description": "Top-level section that groups blog categories"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "order": {
      "type": "integer"
    },
    "blogCategories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-category.blog-category",
      "mappedBy": "section"
    }
  }
}
